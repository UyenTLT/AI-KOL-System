{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "KOL Profile Schema",
  "description": "Standard schema for all KOL character profiles in this database",
  "type": "object",
  "required": ["id", "meta", "identity", "persona", "content", "social"],
  "properties": {
    "id": {
      "type": "string",
      "description": "Unique slug identifier, e.g. sofia-vargas"
    },
    "meta": {
      "type": "object",
      "required": ["created_at", "updated_at", "status", "category"],
      "properties": {
        "created_at": { "type": "string", "format": "date" },
        "updated_at": { "type": "string", "format": "date" },
        "status": { "type": "string", "enum": ["active", "draft", "archived", "photos_collected"] },
        "category": { "type": "string", "description": "Primary KOL category, e.g. lifestyle, gaming, fitness" },
        "gender": { "type": "string", "enum": ["female", "male", "other"], "description": "Optional; defaults to female if omitted" },
        "tags": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Free tags. Encode style-system axes here too, e.g. flavor:F5, flavor:F1, role:R2 (see docs/04-kol-style-system-and-commerce.md)"
        },
        "design_note": { "type": "string", "description": "One-line description of the chosen flavor/blend and boundary" },
        "reference_profiles": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Real-world Instagram handles that inspired this persona (style reference only, never likeness cloning)"
        }
      }
    },
    "identity": {
      "type": "object",
      "required": ["name", "handle", "age", "ethnicity", "origin", "current_location", "languages"],
      "properties": {
        "name": { "type": "string" },
        "name_zh": { "type": "string", "description": "Chinese name (optional)" },
        "handle": { "type": ["string", "null"], "description": "Primary social handle" },
        "age": { "type": "integer" },
        "ethnicity": { "type": "string" },
        "origin": { "type": "string", "description": "City / country of origin" },
        "current_location": { "type": "string" },
        "languages": { "type": "array", "items": { "type": "string" } },
        "appearance": {
          "type": "object",
          "properties": {
            "height": { "type": "string" },
            "hair": { "type": "string" },
            "eyes": { "type": "string" },
            "face": { "type": "string" },
            "build": { "type": "string" },
            "style_vibe": { "type": "string" }
          }
        }
      }
    },
    "persona": {
      "type": "object",
      "required": ["archetype", "personality_traits", "values", "backstory", "voice_tone"],
      "properties": {
        "archetype": { "type": "string" },
        "personality_traits": { "type": "array", "items": { "type": "string" } },
        "values": { "type": "array", "items": { "type": "string" } },
        "backstory": { "type": "string" },
        "voice_tone": { "type": "string" },
        "humor_style": { "type": "string" },
        "quirks": { "type": "array", "items": { "type": "string" } }
      }
    },
    "content": {
      "type": "object",
      "required": ["pillars", "formats", "posting_frequency", "aesthetic"],
      "properties": {
        "pillars": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "name": { "type": "string" },
              "description": { "type": "string" },
              "weight": { "type": "string", "description": "Approximate share of content, e.g. 30%" }
            }
          }
        },
        "formats": { "type": "array", "items": { "type": "string" } },
        "posting_frequency": { "type": "string" },
        "aesthetic": {
          "type": "object",
          "properties": {
            "color_palette": { "type": "array", "items": { "type": "string" } },
            "mood": { "type": "string" },
            "editing_style": { "type": "string" }
          }
        },
        "brand_do": { "type": "array", "items": { "type": "string" } },
        "brand_dont": { "type": "array", "items": { "type": "string" } }
      }
    },
    "social": {
      "type": "object",
      "properties": {
        "platforms": {
          "type": "object",
          "additionalProperties": {
            "type": "object",
            "properties": {
              "handle": { "type": "string" },
              "focus": { "type": "string" },
              "follower_tier": { "type": "string", "enum": ["nano", "micro", "mid", "macro", "mega"] }
            }
          }
        },
        "engagement_style": { "type": "string" },
        "community_name": { "type": "string" }
      }
    },
    "commerce": {
      "type": "object",
      "description": "Commercial role + product knowledge for seller KOLs. See docs/04-kol-style-system-and-commerce.md (Commerce-Role axis) and research/local-ai-companion/11-comment-read-and-act-loop.md.",
      "properties": {
        "role": {
          "type": "string",
          "enum": ["R0-influencer", "R1-soft-seller", "R2-active-seller", "R3-live-closer"],
          "description": "Commerce-role level; drives how aggressively the comment-read-and-act loop converts"
        },
        "categories": { "type": "array", "items": { "type": "string" }, "description": "Product categories she sells / reviews" },
        "sales_channels": { "type": "array", "items": { "type": "string" }, "description": "e.g. Instagram DM, TikTok Shop, affiliate link, own landing page" },
        "product_kb": { "type": ["string", "null"], "description": "Path or URL to the product knowledge base (name, price, link, USP) used for price/link replies" },
        "comment_policy_mode": { "type": "string", "enum": ["suggest", "semi-auto", "auto"], "description": "Human-in-the-loop level for the comment loop; start at suggest" }
      }
    },
    "ai_assets": {
      "type": "object",
      "description": "Identity anchors for consistent generated media (face + voice). Local-first stack per research/local-ai-companion/09 & 10.",
      "additionalProperties": true,
      "properties": {
        "consistency": { "type": "string", "description": "Face-consistency method, e.g. character_lora, reference_element, soul, pulid" },
        "generation_model": { "type": "string", "description": "e.g. flux, seedream, sdxl" },
        "soul_id": { "type": ["string", "null"] },
        "voice": {
          "type": "object",
          "description": "Voice identity for this KOL (see research/local-ai-companion/10-local-voice-stack.md)",
          "properties": {
            "voice_id": { "type": ["string", "null"] },
            "reference_audio": { "type": ["string", "null"], "description": "Path to the reference sample used for cloning" },
            "engine_offline": { "type": "string", "description": "High-quality TTS for video, e.g. F5-TTS-Vietnamese / IndexTTS-2" },
            "engine_realtime": { "type": "string", "description": "Low-latency TTS for live/DM, e.g. CosyVoice2 / GPT-SoVITS" },
            "post_processing": { "type": "string", "description": "e.g. RVC for timbre unification" },
            "notes": { "type": "string" }
          }
        }
      }
    },
    "ai_prompts": {
      "type": "object",
      "description": "Image/video generation prompts and consistency notes",
      "additionalProperties": true
    }
  }
}
